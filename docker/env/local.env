COMPOSE_PROJECT_NAME=hand_isaac_local
CONTAINER_NAME=hand_isaac_local
DOCKER_IMAGE=hand_isaac:5.1.0-lab2.3.2-local
ISAACSIM_BASE_IMAGE=nvcr.io/nvidia/isaac-sim
ISAACSIM_VERSION=5.1.0
HEADLESS=1
SHM_SIZE=8gb
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
