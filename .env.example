DOCKER_ENV_FILE=docker/env/company.env
ISAACSIM_BASE_IMAGE=nvcr.io/nvidia/isaac-sim
ISAACSIM_VERSION=5.1.0
ISAACLAB_GIT_URL=https://github.com/isaac-sim/IsaacLab.git
ISAACLAB_GIT_REF=v2.3.2
RL_GAMES_GIT_URL=https://github.com/isaac-sim/rl_games.git
RL_GAMES_GIT_REF=python3.11
INSTALL_RL_GAMES=0
DOCKER_BUILD_METHOD=direct
BUILDKIT_PROGRESS=auto
COMPOSE_PROJECT_NAME=isaac-ws-company
CONTAINER_NAME=isaac-ws-company
DOCKER_IMAGE=isaac-ws:5.1.0-lab2.3.2
HEADLESS=1
SHM_SIZE=16gb
XAUTHORITY_PATH=/home/your-user/.Xauthority
X11_SOCKET_DIR=/tmp/.X11-unix
ISAACSIM_PATH=/isaac-sim
ISAACSIM_PYTHON_EXE=/isaac-sim/python.sh
QT_X11_NO_MITSHM=1
ACCEPT_EULA=Y
PRIVACY_CONSENT=Y
OMNI_KIT_ACCEPT_EULA=YES
OMNI_KIT_ALLOW_ROOT=1
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
WANDB_MODE=offline
DEFAULT_TASK=grasp_sphere_shadow_hand_only
DEFAULT_ENV=shadow_hand_palm_up
DEFAULT_ROBOT=shadow_hand
DEFAULT_EXPERIMENT=shadow_hand_grasp_bootstrap
ISAAC_WS_OUTPUT_ROOT=/workspace/isaac_ws/runs
ISAAC_WS_LOG_ROOT=/workspace/isaac_ws/logs
ISAAC_WS_CHECKPOINT_ROOT=/workspace/isaac_ws/checkpoints
